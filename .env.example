# .env.example
# Copy this file to .env and fill in your real values.
# The .env file is listed in .gitignore and will NOT be committed.

# ---------------------------------------------------------------------------
# Telegram Bot
# Obtain from @BotFather on Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram chat or channel ID (use @username for public channels, or a numeric
# ID for private chats – get it from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id_here

# ---------------------------------------------------------------------------
# Apify
# Obtain from https://console.apify.com/account/integrations
# ---------------------------------------------------------------------------
APIFY_API_TOKEN=your_apify_token_here

# ---------------------------------------------------------------------------
# Feature flags (set to "false" to disable individual scrapers)
# ---------------------------------------------------------------------------
ENABLE_LOCAL_SCRAPER=true
ENABLE_APIFY_SCRAPER=true
